    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "ログイン。成功するとJWTトークンを返す。",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/bom": {
      "get": {
        "tags": [
          "Bom"
        ],
        "summary": "指定した親品目の BOM（部品表）を取得する。\nasOf を指定すると有効期間内のラインのみ返す（製造指示発行時の引当計算で使用）。",
        "parameters": [
          {
            "name": "parentItemId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "asOf",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Bom"
        ],
        "summary": "BOM に子品目ラインを追加する。",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddBomLineRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddBomLineRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddBomLineRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
